{
    "compilerOptions": {
        "target": "ES2020",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ESNext"
        ],
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "apis/*": [
                "./src/apis/*"
            ],
            "components/*": [
                "./src/components/*"
            ],
            "configs/*": [
                "./src/configs/*"
            ],
            "hooks/*": [
                "./src/hooks/*"
            ],
            "pages/*": [
                "./src/pages/*"
            ],
            "types/*": [
                "./src/types/*"
            ],
            "utils/*": [
                "./src/utils/*"
            ]
        },
        "types": [
            "node",
            "vite/client"
        ],
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "noEmit": true
    },
    "include": [
        "src",
        "vite.config.ts"
    ]
}
