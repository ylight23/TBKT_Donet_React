.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates
*.DotSettings.user

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Coverage / reports
coverage/
*.coverage
TestResults/

# Temp / recovery / ad-hoc scripts
recovery-scan.txt
_tmp_backend_build/
tmp_*.js
tmp_*.ps1
tmp_*.ts
tmp_*.tsx
*.tmp
*.bak
*.orig

# Archives / dumps
*.zip
*.7z
*.rar

